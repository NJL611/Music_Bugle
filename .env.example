# Site
SITE_URL=https://themusicbugle.com

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_API_READ_TOKEN=

# Analytics & consent
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
NEXT_PUBLIC_TERMLY_WEBSITE_UUID=

# AdSense (enable during review)
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=
# Slot ID from a Display ad unit in the AdSense dashboard — responsive units won't fill without it
NEXT_PUBLIC_ADSENSE_AD_SLOT=
NEXT_PUBLIC_SHOW_ADS=true

# Contact form (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=The Music Bugle <noreply@themusicbugle.com>
CONTACT_TO_EMAIL=info@themusicbugle.com

# Social profile URLs (omit any network you do not use)
NEXT_PUBLIC_SOCIAL_TWITTER=https://twitter.com/TheMusicBugle
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_PINTEREST=

# Stripe (support page)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Legacy alias (still supported in code):
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
